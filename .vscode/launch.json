{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Hermes: Build",
      "type": "node-terminal",
      "request": "launch",
      "command": "python3 -m venv .venv && .venv/bin/pip install -e \".[dev,messaging]\"",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Hermes: Gateway",
      "type": "node-terminal",
      "request": "launch",
      "command": ".venv/bin/python -m hermes_cli.main gateway run -v",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Hermes: ngrok",
      "type": "node-terminal",
      "request": "launch",
      "command": "ngrok http 8647"
    },
    {
      "name": "Dashboard",
      "type": "node-terminal",
      "request": "launch",
      "command": ".venv/bin/python -m hermes_cli.main dashboard",
      "cwd": "${workspaceFolder}"
    }
  ]
}
